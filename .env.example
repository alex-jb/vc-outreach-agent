# Required: Anthropic API key. Without it, the agent runs in "template mode"
# (still personalizes via thesis_hint, but lower quality than LLM-drafted).
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: which Claude model to use for drafting.
# VC_OUTREACH_MODEL=claude-sonnet-4-6   # default — cold email needs nuance, Sonnet > Haiku

# Optional: where to put the HITL queue (default: ~/.vc-outreach-agent/queue/)
# VC_OUTREACH_QUEUE=/path/to/your/queue

# Bypass — set to 1 to make the agent a no-op
# VC_OUTREACH_SKIP=0
