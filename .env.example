# Required: Anthropic API key. Without it, the agent runs in "template mode"
# (still personalizes via thesis_hint, but lower quality than LLM-drafted).
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: which Claude model to use for drafting.
# VC_OUTREACH_MODEL=claude-sonnet-4-6   # default — cold email needs nuance, Sonnet > Haiku

# Optional: where to put the HITL queue (default: ~/.vc-outreach-agent/queue/)
# VC_OUTREACH_QUEUE=/path/to/your/queue

# Bypass — set to 1 to make the agent a no-op
# VC_OUTREACH_SKIP=0

# v0.2 — SMTP sender (for `vc-outreach-agent send`)
# Common providers:
#   Gmail:    smtp.gmail.com:587, your gmail + 16-char App Password
#   Postmark: smtp.postmarkapp.com:587, server token as SMTP_USER and SMTP_PASSWORD
#   Resend:   smtp.resend.com:465, "resend" as SMTP_USER, API key as SMTP_PASSWORD
#   Sendgrid: smtp.sendgrid.net:587, "apikey" as SMTP_USER, API key as SMTP_PASSWORD
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# SENDER_DRY_RUN=1   # don't actually send; useful first time
